      "applies_to": ["CLOISTER", "SCIFI_AIRLOCK", "SCI_FI_DECK", "ROMANESQUE_CLOISTER", "VENETIAN_CANAL", "ROMANESQUE_APSE", "SCI_FI_DECK_EXPANSION", "ASIAN_CITY", "tower_generator", "corridor_generator"],
